{
  "name": "cogwork-engine/modpack-manager",
  "description": "Build, maintain, and migrate modpacks",
  "license": "AGPL-3.0-only",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-zip": "*",
    "chillerlan/php-qrcode": "^6.0",
    "web-auth/webauthn-lib": "^5.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {"Modright\\": "app/"}
  },
  "autoload-dev": {
    "psr-4": {"Modright\\Tests\\": "tests/"}
  },
  "scripts": {"test": "phpunit"},
  "config": {"sort-packages": true}
}
